# Dependencies
node_modules/
app/node_modules/
backend/node_modules/

# MongoDB data (never upload to GitHub)
data/db/
data/*.log
data/*.log.*

# Environment files (contains secrets!)
backend/.env
app/.env

# Build output (regenerated on deploy)
app/dist/
backend/public/assets/

# Logs
/tmp/
*.log
nohup.out

# OS
.DS_Store
Thumbs.db

# Uploads (user files)
backend/uploads/*
!backend/uploads/.gitkeep

## Session / browser cache created by wwebjs / puppeteer
backend/.wwebjs_auth/
backend/.wwebjs_cache/

# Environment and local config
.env
.env.*
app/.env.local
backend/.env.local

# Build / tooling
.cache/
.parcel-cache/
dist/
coverage/

# VSCode / IDE
.vscode/
.idea/

# Large DB / runtime data
data/
uploads/

# NPM lock (optional)
# package-lock.json
